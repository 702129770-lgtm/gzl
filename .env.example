# 通知模式：个人快速使用推荐 webhook；团队正式应用可改为 app
FEISHU_NOTIFY_MODE=webhook

# Webhook 快速模式：在飞书群添加“自定义机器人”后复制 Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 可选：如果自定义机器人开启了“签名校验”，填写密钥
FEISHU_WEBHOOK_SECRET=

# 应用机器人模式：FEISHU_NOTIFY_MODE=app 时使用
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：默认发送到哪个接收对象。前端留空时使用这里。
FEISHU_DEFAULT_RECEIVE_ID_TYPE=chat_id
FEISHU_DEFAULT_RECEIVE_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 国内飞书一般使用 https://open.feishu.cn；海外 Lark 可改为 https://open.larksuite.com
FEISHU_API_BASE=https://open.feishu.cn

PORT=3000
